<UserControl x:Class="QueueUpImporter.QueueUpImporterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="500">
    <StackPanel Margin="20">
        <TextBlock Text="QueueUp server URL" Margin="0,0,0,4" />
        <TextBox Text="{Binding Settings.ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                  ToolTip="e.g. https://queueup.example.com (no trailing slash)" Margin="0,0,0,12" />

        <TextBlock Text="API token" Margin="0,0,0,4" />
        <PasswordBox x:Name="ApiTokenBox" Margin="0,0,0,4"
                     PasswordChanged="ApiTokenBox_PasswordChanged" />
        <TextBlock Text="Generate this in QueueUp under Profile Settings &#8594; Playnite import."
                   Opacity="0.7" TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
